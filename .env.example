# Copy to .env.local and fill in from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Razorpay key id (dashboard.razorpay.com → Settings → API Keys).
# Use rzp_test_... for testing; without it, orders are placed as
# "payment link requested" instead of paid online.
VITE_RAZORPAY_KEY_ID=
